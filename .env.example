NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173
JWT_SECRET=change-this-in-production
AUTH_TOKEN_TTL=8h
# Cookie session (httpOnly). Localhost defaults work with Vite proxy.
# Production same-origin reverse proxy: leave defaults.
# Split API domain: COOKIE_SAME_SITE=none COOKIE_SECURE=1 COOKIE_DOMAIN=.example.com
COOKIE_SAME_SITE=lax
COOKIE_SECURE=0
COOKIE_DOMAIN=
RESEND_API_KEY=
EMAIL_FROM=ลี้ไฟเบอร์บอร์ด IPMS <noreply@example.com>
# Optional. Enables Socket.IO multi-instance + shared auth rate limits.
REDIS_URL=
METRICS_TOKEN=
TRUST_PROXY=0
SEED_DEMO_DATA=1
ATTACHMENT_STORAGE_DIR=./storage/issue-attachments
ATTACHMENT_MAX_FILES=15
ATTACHMENT_MAX_BYTES=26214400
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=prdproject
DB_POOL_LIMIT=30
